# ============================================================================
# GitHub 每日盲盒 — 本地开发环境变量样例
# ============================================================================
# 复制本文件为 .env 并填入真实值。.env 已在 .gitignore 中，不会被提交。
#
# 本地跑通用：在项目根目录执行
#   cp .env.example .env
#   (编辑 .env 填入下面的值)
#   cat trending-feed.json | node scripts/github-digest.js > digest.txt
#   cat digest.txt | node scripts/send-email.js --to 你的QQ邮箱
#
# GitHub Actions 部署用：把下面的值配到仓库 Settings → Secrets and variables → Actions
# ============================================================================

# 阿里云百炼 API Key（去 https://bailian.console.aliyun.com/ 创建）
# 路径：百炼控制台 → 模型广场 → deepseek-v4-flash → 开通服务 → API Key 管理 → 创建
ANTHROPIC_AUTH_TOKEN=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 阿里云百炼 OpenAI 兼容端点（通用，fork 用户直接用这个）
# 如果你有百炼业务空间专属端点，可替换成 https://<业务空间id>.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
ANTHROPIC_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型名（DeepSeek-V4-Flash，阿里云百炼上的 deepseek-v4-flash）
ANTHROPIC_MODEL=deepseek-v4-flash

# 你的 QQ 邮箱（收件邮箱 + 发件邮箱，QQ SMTP 用同一个邮箱登录）
QQ_EMAIL=123456789@qq.com

# QQ 邮箱授权码（不是 QQ 密码！）
# 获取：QQ 邮箱网页版 → 设置 → 账号与安全 → IMAP/SMTP 服务 → 开启 → 发短信验证 → 拿 16 位授权码
QQ_SMTP_AUTH_CODE=xxxxxxxxxxxxxxxx
